# OwnMessenger Linux-Konfiguration

PORT=3000
HOST=127.0.0.1
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Die Android-App sollte eine HTTPS-Adresse verwenden.
PUBLIC_BASE_URL=https://DEINE-DOMAIN
REQUIRE_HTTPS=1
TRUST_PROXY=1

# App-Key fuer Android-App.
# Wenn leer, erzeugt install.sh automatisch einen sicheren Key.
APP_TOKEN=

DB_PATH=./data/own_messenger.sqlite
PROVIDER=wwebjs

# Medien-Sicherheit
SECURE_MEDIA_MAX_MB=50
SECURE_MEDIA_MAX_IMAGE_DIMENSION=4096
SECURE_MEDIA_IMAGE_QUALITY=95
SECURE_MEDIA_IMAGE_NO_CHROMA_SUBSAMPLING=1
SECURE_MEDIA_REQUIRE_IMAGE_REENCODE=1

# Audio/Video Re-Encoding mit ffmpeg
SECURE_MEDIA_REQUIRE_REENCODE=1
FFMPEG_PATH=/usr/bin/ffmpeg
SECURE_MEDIA_FFMPEG_TIMEOUT_MS=120000

# Dokumente/PDF/Office standardmaessig blockieren
SECURE_MEDIA_ALLOW_DOCUMENTS=0

# Virenpruefung mit ClamAV
SECURE_MEDIA_CLAMAV=auto
CLAMSCAN_PATH=/usr/bin/clamscan
SECURE_MEDIA_CLAMAV_TIMEOUT_MS=20000

# Sicherheit
APP_KEY_SINGLE_DEVICE=1
SECURITY_DELETE_WA_SESSION_ON_LOCKDOWN=1
SECURITY_AUDIT_LOG=1
SECURITY_AUTH_FAIL_LIMIT=20

CORS_ORIGIN=*

# whatsapp-web.js
WWEBJS_CLIENT_ID=own-messenger-main
WWEBJS_HEADLESS=1
WWEBJS_AUTO_SYNC=1
WWEBJS_DOWNLOAD_MEDIA=1
WWEBJS_CHAT_LIMIT=200
WWEBJS_FETCH_RECENT_MESSAGES=1
WWEBJS_MESSAGE_LIMIT_PER_CHAT=15
WWEBJS_MESSAGE_CHAT_LIMIT=75
WWEBJS_PERIODIC_SYNC_SECONDS=30
WWEBJS_SEND_WAIT_MS=60000
WWEBJS_SYNC_VERBOSE=0
WWEBJS_SYNC_MEMORY_IDS=5000
WWEBJS_USER_AGENT=

# Import / Sync
CHAT_LIMIT=200
FETCH_RECENT_MESSAGES=1
MESSAGE_LIMIT_PER_CHAT=15
MESSAGE_CHAT_LIMIT=75
IMPORT_TO_SERVER=1
DIRECT_DB_FALLBACK=1
SERVER_URL=http://127.0.0.1:3000

# Multi-Account
MAX_WA_ACCOUNTS=5
WWEBJS_AUTOSTART_EMPTY_SECONDARY=0
WWEBJS_PAIRING_WAIT_MS=45000
WWEBJS_PAIRING_INTERVAL_MS=180000
WA_AUTOSTART_EMPTY_SLOTS=0

# WhatsApp-Web.js Stabilitaet
WWEBJS_WEB_VERSION_CACHE=local
WWEBJS_WEB_VERSION_REMOTE=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.3000.1039169958.html
WWEBJS_INIT_RETRIES=7
WWEBJS_TAKEOVER_TIMEOUT_MS=15000
WWEBJS_START_STAGGER_MS=8000
WWEBJS_INIT_TIMEOUT_MS=75000
