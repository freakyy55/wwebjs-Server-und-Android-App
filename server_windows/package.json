{
  "name": "own-messenger-server",
  "version": "1.0.0",
  "description": "OwnMessenger Server-Bridge auf Basis von whatsapp-web.js mit REST, WebSocket, Medien, Anrufliste, Push-Sync, HTTPS-Unterstützung und Multi-Account-Routing.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "reset-db": "node scripts/reset-db.js",
    "test": "mocha \"test/**/*.spec.js\"",
    "test:connection": "mocha \"test/client.spec.js\"",
    "check:wwebjs": "node scripts/check-wwebjs-installed.js",
    "wwebjs:connection-test": "node scripts/wwebjs-connection-test.js",
    "wwebjs:load-chats": "node scripts/wwebjs-load-chats-test.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.18.0",
    "whatsapp-web.js": "^1.34.7",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.5",
    "qrcode": "^1.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "mocha": "^10.8.2",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "sinon": "^17.0.1"
  }
}
