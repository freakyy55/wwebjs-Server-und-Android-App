# Server
PORT=3000
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Secure media pipeline
# Sprachnachrichten/Audio der Android-App (.m4a/audio/mp4) werden unterstützt.
# Incoming files are first stored under uploads/_incoming, then checked and moved to uploads/safe.
# Blocked files go to uploads/quarantine and are never publicly served.
SECURE_MEDIA_MAX_MB=50
SECURE_MEDIA_MAX_IMAGE_DIMENSION=4096
SECURE_MEDIA_IMAGE_QUALITY=95
SECURE_MEDIA_IMAGE_NO_CHROMA_SUBSAMPLING=1
SECURE_MEDIA_REQUIRE_IMAGE_REENCODE=1
# Bilder werden immer neu encodiert. Audio/Video werden mit ffmpeg neu encodiert. Die BAT installiert ffmpeg automatisch.
# 1 = Audio/Video blockieren, wenn ffmpeg fehlt oder re-encode fehlschlaegt. 0 = sonst nur scannen/umbenennen.
SECURE_MEDIA_REQUIRE_REENCODE=1
FFMPEG_PATH=.tools\ffmpeg\bin\ffmpeg.exe
SECURE_MEDIA_FFMPEG_TIMEOUT_MS=120000
# Dokumente/PDF/Office sind standardmaessig blockiert, weil Metadaten dort nicht sicher entfernt werden koennen.
SECURE_MEDIA_ALLOW_DOCUMENTS=0
# auto = clamscan nutzen, wenn installiert. required = blockieren, wenn Scanner fehlt/Fehler hat. Die BAT versucht ClamAV automatisch zu installieren.
SECURE_MEDIA_CLAMAV=auto
CLAMSCAN_PATH=.tools\clamav\clamscan.exe
SECURE_MEDIA_CLAMAV_TIMEOUT_MS=20000
# Server lauscht im sicheren Internetbetrieb nur lokal; Caddy macht HTTPS nach außen.
HOST=127.0.0.1
# Domain, die auf diesen PC/Server zeigt, z. B. chat.deinedomain.de
HTTPS_DOMAIN=
PUBLIC_BASE_URL=https://DEINE-DOMAIN
# 1 = direkte unverschlüsselte HTTP/WSS Zugriffe blockieren, wenn kein HTTPS-Proxy davor ist.
REQUIRE_HTTPS=1

# SQLite DB file. Relative paths are relative to the project root.
DB_PATH=./data/own_messenger.sqlite

# Provider mode:
# mock   = local testing only. Outgoing messages are saved as sent, no external provider.
# bridge = outgoing messages are POSTed to BRIDGE_SEND_URL; inbound events are accepted on /provider/*.
PROVIDER=wwebjs

# Generic provider bridge settings.
# This lets you connect any separate provider later without changing the Android app.
BRIDGE_SEND_URL=http://127.0.0.1:3100/send
BRIDGE_TOKEN=change-me-for-bridge

# App-Key fuer Android-App.
# Wenn gesetzt, braucht jede App diesen Key fuer /api, /ws und /uploads.
# Die START_SERVER_WINDOWS.bat erzeugt automatisch einen sicheren Key, wenn dieser leer ist.
APP_TOKEN=


# Extra Sicherheit
# 1 = der App-Key bindet sich beim ersten erfolgreichen Zugriff an genau ein Geraet.
# Nutzt ein zweites Geraet denselben Key, wird WhatsApp getrennt und die lokale WA-Session geloescht.
APP_KEY_SINGLE_DEVICE=1
SECURITY_DELETE_WA_SESSION_ON_LOCKDOWN=1
SECURITY_AUDIT_LOG=1
SECURITY_AUTH_FAIL_LIMIT=20
# Nur auf 1 setzen, wenn ein Reverse Proxy davor sitzt und du X-Forwarded-For vertraust.
# Wird fuer Caddy/HTTPS benoetigt, damit X-Forwarded-Proto/IP korrekt ausgewertet wird.
TRUST_PROXY=1

# CORS origin. Use * for local development.
CORS_ORIGIN=*

# Real whatsapp-web.js provider settings. QR appears in the server window on first start.
WWEBJS_CLIENT_ID=own-messenger-main
WWEBJS_HEADLESS=1
WWEBJS_AUTO_SYNC=1
WWEBJS_DOWNLOAD_MEDIA=1
WWEBJS_CHAT_LIMIT=200
WWEBJS_FETCH_RECENT_MESSAGES=1
WWEBJS_MESSAGE_LIMIT_PER_CHAT=15
WWEBJS_MESSAGE_CHAT_LIMIT=75
# Regelmaessiger WhatsApp-Sync, damit Nachrichten, die direkt in WhatsApp geschrieben werden, in der App auftauchen. 0 = aus.
WWEBJS_PERIODIC_SYNC_SECONDS=30
WWEBJS_SEND_WAIT_MS=60000
# 0 = weniger Log-Ausgaben beim periodischen Sync. 1 = jeden Chat detailliert loggen.
WWEBJS_SYNC_VERBOSE=0
# Wie viele WhatsApp-Nachrichten-IDs im RAM gemerkt werden, damit periodischer Sync nur neue Nachrichten verarbeitet.
WWEBJS_SYNC_MEMORY_IDS=5000
# Optional: set a Windows-looking browser user agent if WhatsApp shows Mac/Chrome and you dislike it.
WWEBJS_USER_AGENT=

# wwebjs chat import into app DB
CHAT_LIMIT=200
FETCH_RECENT_MESSAGES=1
MESSAGE_LIMIT_PER_CHAT=15
MESSAGE_CHAT_LIMIT=75
IMPORT_TO_SERVER=1
DIRECT_DB_FALLBACK=1
SERVER_URL=http://127.0.0.1:3000


# MULTI-ACCOUNT
# Mehrere WhatsApp-Nummern werden in data/accounts/accounts.json verwaltet.
# Jeder Account hat eigenen App-Key, eigenen QR-Code, eigene WhatsApp-Web-Session
# und eigenen 1-Geraet-Schutz. Der API-Key entscheidet automatisch, welche WA-Nummer genutzt wird.
# Admin-Endpunkte:
# GET  /api/admin/accounts
# POST /api/admin/accounts { "id":"firma", "name":"Firma" }

# WhatsApp-Web.js Stabilitaet
# remote = fixierte WhatsApp-Web-Version laden; hilft gegen Execution-context/Inject-Fehler.
# local = Standard von whatsapp-web.js; none = keinen Cache nutzen.
WWEBJS_WEB_VERSION_CACHE=local
WWEBJS_WEB_VERSION_REMOTE=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.3000.1039169958.html
WWEBJS_INIT_RETRIES=7
WWEBJS_TAKEOVER_TIMEOUT_MS=15000
# Multi-Account Start-Stabilitaet
# Mehrere WhatsApp-Web/Chromium-Profile werden gestaffelt gestartet, damit wa2/wa3 nicht dauerhaft STARTING bleiben.
WWEBJS_START_STAGGER_MS=8000
# Wenn ein Account in dieser Zeit keinen QR/Ready/Error liefert, zeigt die QR-Seite einen sichtbaren Fehler.
WWEBJS_INIT_TIMEOUT_MS=75000
# v0.2.39 Multi-WhatsApp Slots
# Standard: main + wa2 + wa3 + wa4 + wa5. Leere Zusatzslots starten nicht automatisch,
# damit beim Koppeln nicht mehrere WhatsApp-Web-Anmeldungen gleichzeitig kollidieren.
MAX_WA_ACCOUNTS=5
WWEBJS_AUTOSTART_EMPTY_SECONDARY=0
WWEBJS_PAIRING_WAIT_MS=45000
WWEBJS_PAIRING_INTERVAL_MS=180000

# 0 = nur Hauptnummer und bereits gekoppelte Zusatz-Slots automatisch starten.
# 1 = auch leere Slots wa2-wa5 beim Serverstart starten. Normalerweise 0 lassen.
WA_AUTOSTART_EMPTY_SLOTS=0
